{
    "postprocess": ["elm-watch/postprocess.sh"],
    "targets": {
        "main": {
            "inputs": [
                "src/Main.elm"
            ],
            "output": "build/js/Elm.js"
        },
        "options": {
            "inputs": [
               "src/Options.elm"
            ],
            "output": "build/js/OptionsElm.js"
        }
    }
}
